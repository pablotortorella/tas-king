# Copiar a .dev.vars (NO commitear)
# Para desarrollo local

# Usuario simulado (no requiere OAuth en localhost)
DEV_USER_EMAIL=tu@email.com

# Google OAuth (obtener de: https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=tu-id-aqui.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-secret-aqui

# Clave para firmar sesiones (puede ser cualquier string aleatorio)
SESSION_SECRET=cambiar-esto-a-string-aleatorio-largo

# Emails iniciales permitidos (separados por coma)
ALLOWED_EMAILS=tu@email.com,otro@email.com

# Emails que son admin (separados por coma)
ADMIN_EMAILS=tu@email.com
