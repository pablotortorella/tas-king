# Solo para desarrollo local. En producción estos valores son Secrets del Worker.
# Copiá este archivo a .dev.vars y completá los valores.
#
# Con DEV_USER_EMAIL la app local no necesita OAuth (usa un usuario simulado).
DEV_USER_EMAIL=tu@email.com

# Para poder probar el flujo de login OAuth en local (opcional):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Clave aleatoria para firmar cookies de sesión (cualquier string largo sirve en local):
SESSION_SECRET=dev-session-secret-cambiar-en-prod

# Emails con acceso a la app (separados por coma):
ALLOWED_EMAILS=tu@email.com

# Emails con permisos de administrador (separados por coma):
ADMIN_EMAILS=tu@email.com
